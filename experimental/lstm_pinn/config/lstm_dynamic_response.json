{
  "metadata": {
    "stage": "7_lstm_pinn",
    "version": "7.0",
    "created_at": "2025-12-14",
    "description": "LSTM-MLP-PINN 动态响应模型",
    "goal": "使用 LSTM 处理电压时间序列，解决升压/降压滞后问题",
    "improvements": [
      "LSTM 编码器处理电压序列，捕获时序依赖",
      "支持任意电压跳变（升压/降压/部分跳变）",
      "支持多步电压序列（如 0→20→30→20→0）",
      "正确建模升压滞后（电润湿动力学）和降压滞后（表面张力恢复）"
    ],
    "success_criteria": {
      "phi_range": "[0, 1]",
      "volume_conservation_error": "<1%",
      "inference_time_10k_points": "<100ms"
    }
  },
  "lstm_model": {
    "type": "lstm_mlp_pinn",
    "lstm": {
      "input_dim": 3,
      "hidden_dim": 128,
      "num_layers": 2,
      "dropout": 0.1,
      "bidirectional": false
    },
    "phi_decoder": {
      "spatial_dim": 3,
      "hidden_layers": [128, 64, 32],
      "activation": "tanh",
      "use_skip_connections": false
    },
    "velocity_decoder": {
      "enabled": false,
      "hidden_layers": [64, 32],
      "activation": "tanh"
    }
  },
  "sequence": {
    "length": 50,
    "dt": 0.001,
    "t_max": 0.05,
    "_comment": "序列长度50，时间步长1ms，最大时间50ms"
  },
  "training": {
    "epochs": 30000,
    "batch_size": 1024,
    "optimizer": "adam",
    "learning_rate": 0.001,
    "stage1_epochs": 5000,
    "stage2_epochs": 10000,
    "weight_decay": 1e-05,
    "lr_scheduler": null,
    "warmup_epochs": 500,
    "min_lr": 1e-06,
    "early_stopping_patience": 2000,
    "gradient_clip": 1.0,
    "mixed_precision": true
  },
  "data": {
    "n_samples": 100000,
    "train_ratio": 0.7,
    "val_ratio": 0.15,
    "test_ratio": 0.15,
    "voltage_transitions": [
      {"type": "rise", "V_from": 0, "V_to": [10, 20, 30]},
      {"type": "rise", "V_from": 10, "V_to": [20, 30]},
      {"type": "rise", "V_from": 20, "V_to": [30]},
      {"type": "fall", "V_from": [10, 20, 30], "V_to": 0},
      {"type": "partial_fall", "V_from": 30, "V_to": [20, 10]},
      {"type": "partial_fall", "V_from": 20, "V_to": [10]},
      {"type": "multi_step", "sequences": [
        [0, 20, 30, 20, 0],
        [0, 10, 20, 30, 20, 10, 0],
        [0, 30, 0],
        [0, 20, 0]
      ]}
    ],
    "spatial_sampling": {
      "strategy": "interface_weighted",
      "interface_weight": 3.0,
      "resolution": [20, 20, 10]
    }
  },
  "materials": {
    "theta0": 120.0,
    "theta_30V": 67.5,
    "theta_wall": 71.0,
    "epsilon_r": 12.0,
    "epsilon_hydrophobic": 1.9,
    "gamma": 0.015,
    "dielectric_thickness": 4e-07,
    "hydrophobic_thickness": 4e-07,
    "V_threshold": 3.0,
    "aperture_max": 0.85,
    "_comment": "从 device_calibrated_physics.json 继承的材料参数"
  },
  "dynamics": {
    "tau": 0.005,
    "tau_recovery": 0.0075,
    "zeta": 0.8,
    "_comment": "tau=电润湿响应时间常数(5ms), tau_recovery=表面张力恢复时间常数(7.5ms), zeta=阻尼比"
  },
  "geometry": {
    "Lx": 0.000174,
    "Ly": 0.000174,
    "Lz": 2e-05,
    "pixel_size": 0.000174,
    "ink_thickness": 3e-06,
    "wall_height": 3.5e-06,
    "_comment": "从 device_calibrated_physics.json 继承的几何参数"
  },
  "physics_loss": {
    "enabled": true,
    "weights": {
      "continuity": 1.0,
      "vof": 1.0,
      "volume_conservation": 2.0,
      "interface_constraint": 1.0
    },
    "num_collocation_points": 1000
  },
  "loss_weights": {
    "continuity": 1.0,
    "vof": 1.0,
    "ns": 0.1,
    "surface_tension": 0.1,
    "volume": 2.0,
    "interface": 1.0
  },
  "normalization": {
    "voltage": {
      "min": 0,
      "max": 30
    },
    "spatial": {
      "x_scale": 0.000174,
      "y_scale": 0.000174,
      "z_scale": 2e-05
    },
    "time": {
      "scale": 0.001
    }
  },
  "output": {
    "dir": "./outputs_lstm_pinn",
    "save_checkpoints": true,
    "checkpoint_interval": 500,
    "save_best": true
  },
  "seed": 42,
  "deterministic": true
}
